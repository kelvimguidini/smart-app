<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /antigo/

    # Se for a raiz do antigo, vai direto para index.php (evita redirecionamento de diretório que expõe /public)
    RewriteRule ^$ public/index.php [L]

    # Se não for um arquivo existente dentro da pasta public, manda pro index.php
    RewriteCond %{DOCUMENT_ROOT}/antigo/public/$1 !-f
    RewriteRule ^(.*)$ public/index.php [L,QSA]

    # Se for um arquivo existente, serve da pasta public
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
